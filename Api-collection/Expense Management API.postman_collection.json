            {
              "listen": "test",
              "script": {
                "exec": [
                  "const refreshToken = pm.response.json().refreshToken;\r",
                  "const accessToken = pm.response.json().accessToken;\r",
                  "\r",
                  "if(refreshToken) pm.environment.set(\"REFRESH_TOKEN\", refreshToken)\r",
                  "if(accessToken) pm.environment.set(\"TOKEN\", accessToken)"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
